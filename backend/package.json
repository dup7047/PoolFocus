{
  "name": "poolfocus-backend-mvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsc -p tsconfig.json && node dist/test/scoring.test.js && node dist/test/pg-repository.test.js && node dist/test/app-attest.test.js && node dist/test/app-attest-validator.test.js && node dist/test/app-attest-events.test.js && node dist/test/auth-apple.test.js && node dist/test/auth-bearer.test.js && node dist/test/auth-end-to-end.test.js",
    "dev": "tsc -p tsconfig.json && node dist/src/server.js",
    "migrate": "tsc -p tsconfig.json && node dist/src/db/migrate.js",
    "seed": "tsc -p tsconfig.json && node dist/src/db/seed.js",
    "migrate:generate": "drizzle-kit generate",
    "migrate:custom": "drizzle-kit generate --custom"
  },
  "dependencies": {
    "@peculiar/webcrypto": "^1.7.1",
    "@peculiar/x509": "^2.0.0",
    "cbor-x": "^1.6.4",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^4.29.1",
    "jose": "^6.2.3",
    "node-forge": "^1.4.0",
    "pg": "^8.20.0",
    "pkijs": "^3.4.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/node-forge": "^1.3.14",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3"
  }
}
