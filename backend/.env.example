# Copy to .env and adjust for your environment.
# .env is gitignored; never commit secrets.

DATABASE_URL=postgres://poolfocus:poolfocus@localhost:5432/poolfocus_dev
LOG_LEVEL=info
PORT=8080
HOST=0.0.0.0

# /auth/apple — set both to enable the endpoint.
# APPLE_AUDIENCE is the iOS bundle id (or Apple Service ID for web).
# JWT_SECRET must be at least 32 chars; rotating it invalidates all sessions.
APPLE_AUDIENCE=com.dantino.PoolFocus
JWT_SECRET=replace-me-with-a-real-32-or-more-char-secret-in-production

# App Attest (6.1b/6.2). Set APP_ATTEST_REQUIRED=true to reject unsigned events.
APP_ATTEST_APP_ID=ABCDE12345.com.dantino.PoolFocus
APP_ATTEST_REQUIRED=false
APP_ATTEST_ALLOW_DEV=true
